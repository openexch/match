# Resting ask, then an exactly-matching bid. One trade; taker FILLED.
# (The resting maker's fill is conveyed by the TRADE event, not a separate status — the OMS
# derives maker fills from the trade tape. Capturing exactly that is the point.)
MARKET BTC_USD
CLOCK 1000
CREATE u=100 side=ASK type=LIMIT px=60000.0 qty=1.0
CREATE u=200 side=BID type=LIMIT px=60000.0 qty=1.0
