# match#94: requote at a price level pinned live by ANOTHER user's order.
# User B (999) rests one bid at $60,000 that never trades, pinning the level.
# User A (100) then requotes at the SAME price 70 times. Each UPDATE cancel-then-
# replaces, leaving a tombstone the lazy head-advance never reaches (the level never
# trades). The direct book's 64-slot/level cap must NOT be exhausted by those
# tombstones: allocation-pressure compaction reclaims them, so every requote rests as
# NEW, identical to the array book. This scenario is in the CONVERGENT set of the
# A/B equivalence test (direct == array); contrast level_full_reject, which uses 64
# genuinely-live orders and is the one intended divergence.
MARKET BTC_USD
CLOCK 1000
CREATE u=999 side=BID type=LIMIT px=60000.0 qty=1.0
CREATE u=100 side=BID type=LIMIT px=60000.0 qty=1.0
UPDATE u=100 order=2 side=BID px=60000.0 qty=1.0
UPDATE u=100 order=3 side=BID px=60000.0 qty=1.0
UPDATE u=100 order=4 side=BID px=60000.0 qty=1.0
UPDATE u=100 order=5 side=BID px=60000.0 qty=1.0
UPDATE u=100 order=6 side=BID px=60000.0 qty=1.0
UPDATE u=100 order=7 side=BID px=60000.0 qty=1.0
UPDATE u=100 order=8 side=BID px=60000.0 qty=1.0
UPDATE u=100 order=9 side=BID px=60000.0 qty=1.0
