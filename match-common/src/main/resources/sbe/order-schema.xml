<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="com.match.infrastructure.generated"
                   id="1"
                   version="6"
                   semanticVersion="5.2"
                   description="Match Order Schema - Optimized for Ultra-Low Latency"
>
    <types>
        <composite name="messageHeader" description="Message identifiers and length of message root">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>
        <enum name="OrderType" encodingType="uint8">
            <validValue name="LIMIT">0</validValue>
            <validValue name="MARKET">1</validValue>
            <validValue name="LIMIT_MAKER">2</validValue>
        </enum>
        <enum name="OrderSide" encodingType="uint8">
            <validValue name="BID">0</validValue>
            <validValue name="ASK">1</validValue>
        </enum>
        <enum name="CommandType" encodingType="uint8">
            <validValue name="CREATE">0</validValue>
            <validValue name="CANCEL">1</validValue>
            <validValue name="UPDATE">2</validValue>
        </enum>
        <enum name="OrderStatus" encodingType="uint8">
            <validValue name="NEW">0</validValue>
            <validValue name="PARTIALLY_FILLED">1</validValue>
            <validValue name="FILLED">2</validValue>
            <validValue name="CANCELLED">3</validValue>
            <validValue name="REJECTED">4</validValue>
        </enum>
        <enum name="BookUpdateType" encodingType="uint8">
            <validValue name="NEW_LEVEL">0</validValue>
            <validValue name="UPDATE_LEVEL">1</validValue>
            <validValue name="DELETE_LEVEL">2</validValue>
        </enum>
        <!-- Group size encoding for variable-length groups -->
        <composite name="groupSizeEncoding" description="Repeating group dimensions">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="numInGroup" primitiveType="uint16"/>
        </composite>
        <!-- Order reject/terminal reason code carried on order-status egress (SBE v6, match#75).
             Raw OrderRejectReason value (0=NONE on non-rejects; PRICE_OFF_TICK, PRICE_OUT_OF_RANGE,
             OVERFLOW, INVALID_QUANTITY, MATCH_LIMIT, LEVEL_FULL, BOOK_FULL, WOULD_CROSS,
             NO_LIQUIDITY, ORDER_NOT_FOUND on rejects/terminals). presence="optional" with
             nullValue=255 so a pre-v6 stream decodes as 255 = "unknown / upstream too old to say";
             callers (OMS) map 255 to null. Codes never reach 255, so null is unambiguous. -->
        <type name="RejectReasonCode" primitiveType="uint8" presence="optional" nullValue="255"/>
    </types>

    <!-- Optimized: All numeric fields, no string parsing -->
    <sbe:message name="CreateOrder" id="1" description="Create order event">
        <field name="userId" id="1" type="int64"/>
        <field name="price" id="2" type="int64"/>
        <field name="quantity" id="3" type="int64"/>
        <field name="totalPrice" id="4" type="int64"/>
        <field name="marketId" id="5" type="int32"/>
        <field name="orderType" id="6" type="OrderType"/>
        <field name="orderSide" id="7" type="OrderSide"/>
        <field name="omsOrderId" id="8" type="int64"/>
    </sbe:message>

    <sbe:message name="CancelOrder" id="2" description="Cancel order event">
        <field name="userId" id="1" type="int64"/>
        <field name="orderId" id="2" type="int64"/>
        <field name="marketId" id="3" type="int32"/>
    </sbe:message>

    <sbe:message name="UpdateOrder" id="3" description="Update order event">
        <field name="userId" id="1" type="int64"/>
        <field name="orderId" id="2" type="int64"/>
        <field name="price" id="3" type="int64"/>
        <field name="quantity" id="4" type="int64"/>
        <field name="marketId" id="5" type="int32"/>
        <field name="orderType" id="6" type="OrderType"/>
        <field name="orderSide" id="7" type="OrderSide"/>
    </sbe:message>

    <!-- ========== OUTBOUND MESSAGES (Server to Client) ========== -->

    <!-- Trade Execution - Published for each match during order processing -->
    <sbe:message name="TradeExecution" id="4" description="Trade execution/fill event">
        <field name="tradeId" id="1" type="int64"/>
        <field name="takerOrderId" id="2" type="int64"/>
        <field name="makerOrderId" id="3" type="int64"/>
        <field name="takerUserId" id="4" type="int64"/>
        <field name="makerUserId" id="5" type="int64"/>
        <field name="price" id="6" type="int64"/>
        <field name="quantity" id="7" type="int64"/>
        <field name="marketId" id="8" type="int32"/>
        <field name="takerSide" id="9" type="OrderSide"/>
        <field name="timestamp" id="10" type="int64"/>
        <field name="takerOmsOrderId" id="11" type="int64"/>
        <field name="makerOmsOrderId" id="12" type="int64"/>
    </sbe:message>

    <!-- Order Status Update - Published when order state changes -->
    <sbe:message name="OrderStatusUpdate" id="5" description="Order status update">
        <field name="orderId" id="1" type="int64"/>
        <field name="userId" id="2" type="int64"/>
        <field name="price" id="3" type="int64"/>
        <field name="remainingQty" id="4" type="int64"/>
        <field name="filledQty" id="5" type="int64"/>
        <field name="marketId" id="6" type="int32"/>
        <field name="orderSide" id="7" type="OrderSide"/>
        <field name="status" id="8" type="OrderStatus"/>
        <field name="timestamp" id="9" type="int64"/>
        <field name="omsOrderId" id="10" type="int64"/>
        <!-- match#75: engine reject/terminal reason. Message TAIL extension (sinceVersion=6):
             old peers skip it via the message blockLength; new peers reading a v5 stream get
             nullValue 255 (unknown). 0 = NONE on non-rejects. -->
        <field name="rejectReason" id="11" type="RejectReasonCode" sinceVersion="6"/>
    </sbe:message>

    <!-- Order Book Update - Published for level changes -->
    <sbe:message name="OrderBookUpdate" id="6" description="Order book level update">
        <field name="price" id="1" type="int64"/>
        <field name="quantity" id="2" type="int64"/>
        <field name="orderCount" id="3" type="int32"/>
        <field name="marketId" id="4" type="int32"/>
        <field name="side" id="5" type="OrderSide"/>
        <field name="updateType" id="6" type="BookUpdateType"/>
        <field name="timestamp" id="7" type="int64"/>
    </sbe:message>

    <!-- ========== CONTROL MESSAGES ========== -->

    <!-- Cluster Heartbeat - Egress keep-warm sent by the leader to all sessions
         when no market data has flowed for ~1s. Keeps gateway stale-egress
         detection healthy during idle periods. Session liveness itself is
         handled by Aeron's protocol-level keep-alive (AeronCluster.sendKeepAlive),
         which never enters the Raft log. -->
    <sbe:message name="ClusterHeartbeat" id="21" description="Cluster egress keep-warm heartbeat">
        <field name="nodeId" id="1" type="int64"/>
        <field name="timestamp" id="2" type="int64"/>
    </sbe:message>

    <!-- ========== EGRESS BATCH MESSAGES (Cluster to Gateway) ========== -->

    <!-- Book Snapshot - Full order book state with bid/ask levels -->
    <sbe:message name="BookSnapshot" id="22" description="Order book snapshot with all levels">
        <field name="marketId" id="1" type="int32"/>
        <field name="timestamp" id="2" type="int64"/>
        <field name="bidVersion" id="3" type="int64"/>
        <field name="askVersion" id="4" type="int64"/>
        <!-- Single monotonic per-book version (v4): derived from the Aeron log
             position of the last mutating command, so it is deterministic
             across replicas and never regresses across restarts/failovers.
             Chains snapshots and deltas for client-side stitching. -->
        <field name="bookVersion" id="5" type="int64" sinceVersion="4"/>
        <group name="bids" id="10" dimensionType="groupSizeEncoding">
            <field name="price" id="1" type="int64"/>
            <field name="quantity" id="2" type="int64"/>
            <field name="orderCount" id="3" type="int32"/>
        </group>
        <group name="asks" id="11" dimensionType="groupSizeEncoding">
            <field name="price" id="1" type="int64"/>
            <field name="quantity" id="2" type="int64"/>
            <field name="orderCount" id="3" type="int32"/>
        </group>
    </sbe:message>

    <!-- Trades Batch - Aggregated trades within flush interval -->
    <sbe:message name="TradesBatch" id="23" description="Batch of aggregated trades">
        <field name="marketId" id="1" type="int32"/>
        <field name="timestamp" id="2" type="int64"/>
        <group name="trades" id="10" dimensionType="groupSizeEncoding">
            <field name="price" id="1" type="int64"/>
            <field name="quantity" id="2" type="int64"/>
            <field name="tradeCount" id="3" type="int32"/>
            <field name="timestamp" id="4" type="int64"/>
            <!-- Taker (aggressor) side of the aggregated bucket (v5): trades
                 are aggregated per (price, taker side), so every entry has a
                 uniform side. sinceVersion=5 group TAIL extension: old peers
                 skip it via the on-wire group blockLength (groupSizeEncoding);
                 new peers reading v4 streams get OrderSide.NULL_VAL. Same
                 mixed-version pattern as OrderStatusBatch.statusSeq (v3). -->
            <field name="takerSide" id="5" type="OrderSide" sinceVersion="5"/>
        </group>
    </sbe:message>

    <!-- Order Status Batch - Multiple order status updates -->
    <!-- P1.2 (match#31): OMS -> cluster request to re-emit the open-order set
         (logged/deterministic command; only the leader emits the reply). Sent on
         egress reconnect and on detected statusSeq/tradeId gaps. -->
    <sbe:message name="RequestOpenOrdersSnapshot" id="7" description="OMS requests an OpenOrdersSnapshot egress">
        <field name="requestId" id="1" type="int64"/>
    </sbe:message>

    <!-- P1.2 (match#31): cluster -> OMS open-order membership snapshot, chunked.
         snapshotMaxOrderId is the orderId generator's value at emission: OMS only
         terminalizes absent orders with clusterOrderId <= this cutoff (orders
         created after the snapshot are legitimately missing from it). -->
    <sbe:message name="OpenOrdersSnapshot" id="27" description="Open-order membership snapshot for OMS reconciliation">
        <field name="requestId" id="1" type="int64"/>
        <field name="snapshotMaxOrderId" id="2" type="int64"/>
        <field name="chunkIndex" id="3" type="int32"/>
        <field name="isLast" id="4" type="uint8"/>
        <group name="orders" id="10" dimensionType="groupSizeEncoding">
            <field name="orderId" id="1" type="int64"/>
            <field name="omsOrderId" id="2" type="int64"/>
        </group>
    </sbe:message>

    <sbe:message name="OrderStatusBatch" id="24" description="Batch of order status updates">
        <field name="marketId" id="1" type="int32"/>
        <field name="timestamp" id="2" type="int64"/>
        <group name="orders" id="10" dimensionType="groupSizeEncoding">
            <field name="orderId" id="1" type="int64"/>
            <field name="userId" id="2" type="int64"/>
            <field name="status" id="3" type="OrderStatus"/>
            <field name="price" id="4" type="int64"/>
            <field name="remainingQty" id="5" type="int64"/>
            <field name="filledQty" id="6" type="int64"/>
            <field name="side" id="7" type="OrderSide"/>
            <field name="timestamp" id="8" type="int64"/>
            <field name="omsOrderId" id="9" type="int64"/>
            <!-- P1.2 (match#31): per-market monotonic sequence assigned at the
                 drop-or-buffer decision, so publisher-side drops surface as gaps
                 the OMS can detect. Resets on leader change (OMS rebaselines on
                 reconnect). sinceVersion=3: old peers ignore, new peers reading
                 old streams get the null value. -->
            <field name="statusSeq" id="11" type="int64" sinceVersion="3"/>
            <!-- match#75: engine reject/terminal reason, per-order. Group TAIL extension
                 (sinceVersion=6): old peers skip it via the on-wire group blockLength
                 (groupSizeEncoding), new peers reading a pre-v6 stream get nullValue 255
                 (unknown). Same mixed-version pattern as statusSeq (v3) and TradesBatch.takerSide
                 (v5). 0 = NONE on non-rejects. -->
            <field name="rejectReason" id="12" type="RejectReasonCode" sinceVersion="6"/>
        </group>
    </sbe:message>

    <!-- Trade Execution Batch - Full per-trade details for OMS settlement -->
    <sbe:message name="TradeExecutionBatch" id="26" description="Batch of individual trade executions with full details">
        <field name="marketId" id="1" type="int32"/>
        <field name="timestamp" id="2" type="int64"/>
        <group name="trades" id="10" dimensionType="groupSizeEncoding">
            <field name="tradeId" id="1" type="int64"/>
            <field name="takerOrderId" id="2" type="int64"/>
            <field name="makerOrderId" id="3" type="int64"/>
            <field name="takerUserId" id="4" type="int64"/>
            <field name="makerUserId" id="5" type="int64"/>
            <field name="price" id="6" type="int64"/>
            <field name="quantity" id="7" type="int64"/>
            <field name="takerSide" id="8" type="OrderSide"/>
            <field name="takerOmsOrderId" id="9" type="int64"/>
            <field name="makerOmsOrderId" id="10" type="int64"/>
        </group>
    </sbe:message>

    <!-- Book Delta - Incremental book level changes (reduces bandwidth vs full snapshots) -->
    <sbe:message name="BookDelta" id="25" description="Incremental book level changes">
        <field name="marketId" id="1" type="int32"/>
        <field name="timestamp" id="2" type="int64"/>
        <field name="bidVersion" id="3" type="int64"/>
        <field name="askVersion" id="4" type="int64"/>
        <!-- v4 book-version chain: this delta advances the book from
             fromVersion to bookVersion. A client whose current version is not
             fromVersion has missed an update and must re-snapshot. -->
        <field name="bookVersion" id="5" type="int64" sinceVersion="4"/>
        <field name="fromVersion" id="6" type="int64" sinceVersion="4"/>
        <group name="changes" id="10" dimensionType="groupSizeEncoding">
            <field name="price" id="1" type="int64"/>
            <field name="quantity" id="2" type="int64"/>
            <field name="orderCount" id="3" type="int32"/>
            <field name="side" id="4" type="OrderSide"/>
            <field name="updateType" id="5" type="BookUpdateType"/>
        </group>
    </sbe:message>

</sbe:messageSchema>
